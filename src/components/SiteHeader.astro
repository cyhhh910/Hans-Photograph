---
import type { Lang } from '../lib/i18n';

type Props = {
  lang?: Lang;
};

const { lang = 'zh' } = Astro.props;
const basePath = lang === 'en' ? '/en' : '';

const links = [
  { href: `${basePath}/works`, label: lang === 'zh' ? '作品' : 'Works' },
  { href: `${basePath}/about`, label: lang === 'zh' ? '关于' : 'About' }
];

const currentPath = Astro.url.pathname;
const switchHref =
  lang === 'en'
    ? currentPath.replace(/^\/en(?=\/|$)/, '') || '/'
    : `/en${currentPath === '/' ? '' : currentPath}`;
---

<header class="sticky top-0 z-10 border-b border-zinc-200/80 bg-zinc-50/85 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 lg:px-10">
    <a class="text-base font-semibold tracking-tight" href={basePath || '/'}>Hans Cao</a>
    <ul class="flex items-center gap-6 text-sm font-medium text-zinc-700">
      {
        links.map((link) => (
          <li>
            <a class="transition hover:text-zinc-950" href={link.href}>{link.label}</a>
          </li>
        ))
      }
      <li>
        <a class="rounded-full border border-zinc-200 px-2.5 py-1 text-xs text-zinc-500 hover:text-zinc-900" href={switchHref}>
          {lang === 'zh' ? 'EN' : '中文'}
        </a>
      </li>
    </ul>
  </nav>
</header>
