---
import type { PhotoItem } from '../types/photo';
import type { Lang } from '../lib/i18n';
import { getLocalizedPhotoText } from '../lib/i18n';

type Props = {
  photo: PhotoItem;
  lang?: Lang;
  basePath?: string;
};

const { photo, lang = 'zh', basePath = '' } = Astro.props;
const text = getLocalizedPhotoText(photo, lang);
const locationTrackingClass = lang === 'en' ? 'tracking-[0.08em]' : 'tracking-[0.22em]';
---

<article class="group break-inside-avoid">
  <a href={`${basePath}/photo/${photo.slug}`} class="block aspect-[4/5] overflow-hidden rounded-sm bg-zinc-200">
    <img
      src={photo.imageUrl}
      alt={text.title}
      loading="lazy"
      class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.01] group-hover:opacity-95"
    />
  </a>
  <div class="mt-2 flex items-start justify-between gap-3">
    <div>
      <h3 class="text-sm font-medium">{text.title}</h3>
      <p class={`mt-1 text-[10px] ${locationTrackingClass} text-zinc-500`}>{text.location}</p>
    </div>
    <p class="text-[10px] text-zinc-500">{photo.capturedAt}</p>
  </div>
</article>
