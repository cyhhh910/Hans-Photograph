---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import FilterBar from '../../components/FilterBar.astro';
import PhotoCard from '../../components/PhotoCard.astro';
import { getAllPhotos } from '../../lib/sanity';
import { getLocalizedPhotoText, getLocalizedTagName } from '../../lib/i18n';

const photos = await getAllPhotos();
const lang = 'en';
const selectedTag = Astro.url.searchParams.get('tag') ?? 'all';
const selectedCity = Astro.url.searchParams.get('city') ?? 'all';

const tagsMap = new Map(photos.flatMap((photo) => photo.tags.map((tag) => [tag.slug, getLocalizedTagName(tag, lang)] as const)));
const allTags = [{ value: 'all', label: 'All Tags' }].concat(
  [...tagsMap.entries()].map(([value, label]) => ({ value, label }))
);
const cityMap = new Map(photos.map((photo) => [photo.city, getLocalizedPhotoText(photo, lang).city] as const));
const allCities = [{ value: 'all', label: 'All Cities' }].concat(
  [...cityMap.entries()].map(([value, label]) => ({ value, label }))
);

const filtered = photos.filter((photo) => {
  const tagPass = selectedTag === 'all' || photo.tags.some((tag) => tag.slug === selectedTag);
  const cityPass = selectedCity === 'all' || photo.city === selectedCity;
  return tagPass && cityPass;
});
---

<BaseLayout title="Works | Hans Cao Photograph" description="Browse photography works by tag and city.">
  <SiteHeader lang={lang} />
  <main class="mx-auto max-w-7xl space-y-12 px-6 py-12 lg:px-10">
    <section class="space-y-8">
      <h1 class="text-3xl font-semibold tracking-tight">Works</h1>
      <div class="grid gap-8 lg:grid-cols-2">
        <FilterBar
          title="Tag"
          options={allTags}
          selected={selectedTag}
          paramName="tag"
          basePath="/en/works"
          preserve={{ city: selectedCity === 'all' ? undefined : selectedCity }}
        />
        <FilterBar
          title="City"
          options={allCities}
          selected={selectedCity}
          paramName="city"
          basePath="/en/works"
          preserve={{ tag: selectedTag === 'all' ? undefined : selectedTag }}
        />
      </div>
    </section>

    <section class="columns-1 gap-6 sm:columns-2 lg:columns-3">
      {filtered.map((photo) => <div class="mb-7"><PhotoCard photo={photo} lang={lang} basePath="/en" /></div>)}
    </section>
  </main>
</BaseLayout>
