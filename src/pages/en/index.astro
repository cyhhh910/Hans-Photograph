---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { getAllPhotos } from '../../lib/sanity';
import { getLocalizedPhotoText } from '../../lib/i18n';

const photos = await getAllPhotos();
const lang = 'en';
const slides = photos.map((photo) => {
  const text = getLocalizedPhotoText(photo, lang);
  return {
    href: `/en/photo/${photo.slug}`,
    imageUrl: photo.imageUrl,
    title: text.title
  };
});
---

<BaseLayout title="Hans Cao Photograph" description="Minimal portfolio website for Hans Cao's photography works.">
  <SiteHeader lang={lang} />
  <main class="mx-auto grid max-w-7xl grid-cols-1 gap-10 px-6 py-10 lg:grid-cols-2 lg:items-center lg:gap-10 lg:px-10 lg:py-12">
    <section class="flex flex-col justify-center">
      <p class="mb-5 inline-flex w-fit rounded-full border border-zinc-200 px-4 py-1.5 text-xs uppercase tracking-[0.24em] text-zinc-400">
        Established 2026
      </p>
      <h1
        class="max-w-xl text-4xl font-medium uppercase leading-[0.92] tracking-tight lg:text-6xl"
        style="font-family: 'Times New Roman', Times, serif;"
      >
        Hans Cao Photograph
      </h1>
      <a
        href="/en/works"
        class="mt-8 inline-flex w-fit items-center gap-3 text-sm uppercase tracking-[0.24em] text-zinc-500 transition hover:text-zinc-950"
      >
        Enter Gallery
        <span aria-hidden="true" class="h-px w-12 bg-zinc-300" />
      </a>
    </section>

    <section
      id="home-random-wrap-en"
      class="relative flex min-h-[380px] items-center justify-center overflow-hidden lg:h-[78vh] lg:max-h-[760px]"
    >
      <a id="home-random-link-en" href={slides[0]?.href ?? '/en/works'} class="block h-full w-full">
        <img
          id="home-random-image-en"
          src={slides[0]?.imageUrl ?? '/images/hero-city.png'}
          alt={slides[0]?.title ?? 'Photo'}
          class="h-full w-full scale-[1.14] object-contain object-center transition-opacity duration-700"
        />
      </a>
    </section>
  </main>
</BaseLayout>

<script define:vars={{ slides }}>
  const list = Array.isArray(slides) ? slides : [];
  const imageEl = document.getElementById('home-random-image-en');
  const linkEl = document.getElementById('home-random-link-en');
  const wrapEl = document.getElementById('home-random-wrap-en');
  if (!imageEl || !linkEl || list.length < 2) {
    // no-op when there are too few images
  } else {
    let current = 0;
    let paused = false;
    const pickNext = () => {
      if (paused) return;
      let next = current;
      while (next === current) {
        next = Math.floor(Math.random() * list.length);
      }
      current = next;
      imageEl.style.opacity = '0.25';
      window.setTimeout(() => {
        const item = list[current];
        imageEl.src = item.imageUrl;
        imageEl.alt = item.title;
        linkEl.href = item.href;
        imageEl.style.opacity = '1';
      }, 320);
    };
    window.setInterval(pickNext, 6500);
    if (wrapEl) {
      wrapEl.addEventListener('mouseenter', () => {
        paused = true;
      });
      wrapEl.addEventListener('mouseleave', () => {
        paused = false;
      });
    }
  }
</script>
