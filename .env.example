PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2025-03-01

# Vercel Deploy Hook (Project → Settings → Git → Deploy Hooks). Used only for local checks:
#   npm run deploy:trigger
# Do not commit a real URL. For auto-deploy on Sanity publish, create a Sanity webhook with this same URL
# (Manage → API → Webhooks, or: npm run sanity:hooks:create) and trigger on create/update/delete as needed.
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
